# --- 2. Feature Engineering (90+ feature pipeline concept) [citation:2] ---
def calculate_technical_indicators(df):
    """Calculates a rich set of technical indicators (mimicking a 90+ feature pipeline)."""
    # Simple Moving Averages
    for window in [5, 10, 20, 50, 100]:
        df[f'sma_{window}'] = df['Close'].rolling(window).mean()
        df[f'ema_{window}'] = df['Close'].ewm(span=window, adjust=False).mean()

    # Volatility
    df['high_low_ratio'] = df['High'] / df['Low']
    df['close_open_ratio'] = df['Close'] / df['Open']
    df['atr_14'] = df['High'].rolling(14).max() - df['Low'].rolling(14).min()

    # Momentum Oscillators
    df['rsi_14'] = 100 - (100 / (1 + df['Close'].diff().apply(lambda x: max(x, 0)).rolling(14).mean() /
                                 df['Close'].diff().apply(lambda x: abs(min(x, 0))).rolling(14).mean()))

    # MACD
    exp1 = df['Close'].ewm(span=12, adjust=False).mean()
    exp2 = df['Close'].ewm(span=26, adjust=False).mean()
    df['macd'] = exp1 - exp2
    df['macd_signal'] = df['macd'].ewm(span=9, adjust=False).mean()
    df['macd_diff'] = df['macd'] - df['macd_signal']

    # Bollinger Bands
    df['bb_middle'] = df['Close'].rolling(20).mean()
    bb_std = df['Close'].rolling(20).std()
    df['bb_high'] = df['bb_middle'] + 2 * bb_std
    df['bb_low'] = df['bb_middle'] - 2 * bb_std

    # Volume-based features
    df['volume_sma_5'] = df['Volume'].rolling(5).mean()
    df['volume_ratio'] = df['Volume'] / df['volume_sma_5']

    # Fractional Differentiation Concept (simplified) [citation:2]
    df['frac_diff_05'] = df['Close'].diff() / (df['Close'] * 0.05 + 1)

    return df


# --- 3. Market Regime Detection (GMM/VAE concept) [citation:1][citation:2] ---
def detect_market_regime(df):
    """Simplified market regime detection based on volatility and trend."""
    # Calculate 20-day volatility and a simple trend measure
    df['volatility'] = df['Close'].pct_change().rolling(20).std() * np.sqrt(252)
    df['trend_strength'] = df['Close'].pct_change(20)

    # Classify regimes
    conditions = [
        (df['volatility'] < df['volatility'].quantile(0.3)) & (df['trend_strength'].abs() < 0.05),
        (df['volatility'] < df['volatility'].quantile(0.3)) & (df['trend_strength'] > 0.05),
        (df['volatility'] < df['volatility'].quantile(0.3)) & (df['trend_strength'] < -0.05),
        (df['volatility'] >= df['volatility'].quantile(0.3))
    ]
    choices = ['Low Vol - Ranging', 'Low Vol - Bullish Trend', 'Low Vol - Bearish Trend', 'High Volatility Regime']
    df['regime'] = np.select(conditions, choices, default='Unknown')
    return df


# --- 4. Custom Trading Environment (Gymnasium) [citation:3][citation:6] ---
class TradingEnv(gym.Env):
    """A custom Gym environment for training a reinforcement learning trading agent."""

    def __init__(self, df, initial_balance=10000, max_steps=1000):
        super(TradingEnv, self).__init__()
        self.df = df
        self.initial_balance = initial_balance
        self.max_steps = max_steps
        self.current_step = 0

        # Action space: 0: Hold, 1: Buy, 2: Sell
        self.action_space = spaces.Discrete(3)

        # Observation space: [Close, SMA_10, SMA_50, RSI, Volatility, Portfolio Value, Shares Held, Regime Encoding]
        self.observation_space = spaces.Box(low=-np.inf, high=np.inf, shape=(8,), dtype=np.float32)

    def reset(self, seed=None, options=None):
        super().reset(seed=seed)
        self.current_step = 50  # Start after warm-up for indicators
        self.balance = self.initial_balance
        self.shares_held = 0
        self.portfolio_value = self.initial_balance
        self.last_trade = 'Hold'
        self.returns = []
        self.done = False
        return self._get_obs(), {}

    def step(self, action):
        if self.done or self.current_step >= len(self.df) - 1:
            self.done = True
            return self._get_obs(), 0, True, False, {}

        current_price = self.df.iloc[self.current_step]['Close']
        next_price = self.df.iloc[self.current_step + 1]['Close'] if self.current_step + 1 < len(
            self.df) else current_price
        regime = self.df.iloc[self.current_step]['regime']

        # Execute action
        if action == 1:  # Buy
            if self.balance > 0:
                shares_to_buy = self.balance * 0.95 // current_price
                self.shares_held += shares_to_buy
                self.balance -= shares_to_buy * current_price
                self.last_trade = 'Buy'
        elif action == 2:  # Sell
            if self.shares_held > 0:
                self.balance += self.shares_held * current_price
                self.shares_held = 0
                self.last_trade = 'Sell'
        else:
            self.last_trade = 'Hold'

        # Update portfolio value
        self.portfolio_value = self.balance + self.shares_held * current_price

        # Calculate reward (Kelly Criterion-inspired [citation:1], Sharpe Ratio consideration [citation:6])
        reward = 0
        if self.current_step > 51:
            price_change = (next_price - current_price) / current_price
            # Reward for profitable trades, penalize for holding through drawdowns
            if action == 1 and price_change > 0:
                reward += 0.5  # Reward for correctly buying
            elif action == 2 and price_change < 0:
                reward += 0.5  # Reward for correctly selling
            elif action == 0 and abs(price_change) < 0.005:
                reward += 0.1  # Small reward for holding steady in a low-volatility regime

            # Penalize for holding too long in a bearish trend
            if 'Bearish Trend' in regime and action == 0 and price_change < 0:
                reward -= 0.2

            # Risk-adjusted reward: Combine monetary gain with drawdown penalty (VaR concept) [citation:1]
            daily_return = (self.portfolio_value - self.initial_balance) / self.initial_balance
            self.returns.append(daily_return)

            # Penalize for large drawdowns
            if len(self.returns) > 20:
                rolling_max = pd.Series(self.returns).rolling(20, min_periods=1).max()
                drawdown = (rolling_max.iloc[-1] - daily_return) / (rolling_max.iloc[-1] + 1e-6)
                if drawdown > 0.1:  # 10% drawdown penalty
                    reward -= 0.5 * drawdown

        self.current_step += 1
        self.done = self.current_step >= len(self.df) - 2 or self.current_step >= self.max_steps

        return self._get_obs(), reward, self.done, False, {}

    def _get_obs(self):
        """Creates the observation vector."""
        row = self.df.iloc[self.current_step]
        # Regime encoding
        regime_encoding = {'Low Vol - Ranging': 0, 'Low Vol - Bullish Trend': 1,
                           'Low Vol - Bearish Trend': 2, 'High Volatility Regime': 3}.get(row['regime'], 0)
        obs = np.array([
            row['Close'] / 1000,  # Normalized price
            row['sma_10'] / 1000 if 'sma_10' in row else row['Close'] / 1000,
            row['sma_50'] / 1000 if 'sma_50' in row else row['Close'] / 1000,
            row['rsi_14'] / 100 if 'rsi_14' in row else 0.5,
            row['volatility'] if 'volatility' in row else 0.1,
            self.portfolio_value / self.initial_balance,
            self.shares_held / 100,
            regime_encoding / 3
        ], dtype=np.float32)
        return obs


# --- 5. The Core AI System (Ensemble + DRL) [citation:1][citation:2] ---
class AIQuantDART:
    """The combined AI Quant Platform and DART Agent."""

    def __init__(self, df, ticker):
        self.df = df
        self.ticker = ticker
        self.env = None
        self.model = None
        self.ensemble_model = None
        self.scaler = None
        self.is_trained = False

    def train(self, total_timesteps=10000):
        """Trains the DRL agent (Soft Actor-Critic is used, but PPO is more available in SB3)."""
        with st.spinner(f"Training DRL Agent for {total_timesteps} steps... This may take a moment."):
            # Create and wrap the environment
            self.env = DummyVecEnv([lambda: TradingEnv(self.df.copy())])

            # Training the RL agent (Using PPO as a strong baseline for continuous action environments)
            # In a full DART implementation, this would be SAC (Soft Actor-Critic) [citation:1]
            self.model = PPO('MlpPolicy', self.env, verbose=0, learning_rate=0.0003, n_steps=2048)
            self.model.learn(total_timesteps=total_timesteps)

            # Simulate Ensemble Model Training (Random Forest as meta-learner) [citation:1][citation:2]
            # This is a simplification: we're using the RL model's experience to train a secondary model
            st.info("Training Ensemble Model (Random Forest Regressor) on RL-generated data...")
            X_train, y_train = [], []
            for i in range(50, min(len(self.df), 200)):
                obs = TradingEnv(self.df)._get_obs()
                X_train.append(obs)
                # Target: future price direction as a proxy for the RL action
                future_price = self.df.iloc[min(i + 5, len(self.df) - 1)]['Close']
                y_train.append(1 if future_price > self.df.iloc[i]['Close'] else 0)

            self.scaler = StandardScaler()
            X_train_scaled = self.scaler.fit_transform(X_train)
            self.ensemble_model = RandomForestRegressor(n_estimators=50, max_depth=5, random_state=42)
            self.ensemble_model.fit(X_train_scaled, y_train)
            self.is_trained = True
            st.success("Training Complete!")

    def generate_strategy(self, current_data_point):
        """Generates a trading signal with uncertainty quantification."""
        if not self.is_trained:
            return {"direction": "Hold", "confidence": 0, "uncertainty": 1}

        # 1. RL Agent Prediction
        obs = np.array([TradingEnv(self.df)._get_obs()])
        action, _ = self.model.predict(obs, deterministic=True)
        action_map = {0: "Hold", 1: "Buy", 2: "Sell"}
        rl_direction = action_map[int(action[0])]

        # 2. Ensemble Model Prediction (Meta-labeling concept) [citation:1][citation:2]
        obs_scaled = self.scaler.transform(obs)
        ensemble_pred = self.ensemble_model.predict(obs_scaled)
        ensemble_prob = max(0.5, min(0.8, ensemble_pred[0] * 0.8 + 0.2))  # Calibrate probability

        # 3. Final Decision based on combined signals
        # If both RL and Ensemble agree, high confidence
        if (rl_direction == "Buy" and ensemble_pred[0] > 0.5) or (rl_direction == "Sell" and ensemble_pred[0] < 0.5):
            final_direction = rl_direction
            confidence = 0.7 + (ensemble_prob - 0.5) * 0.4  # Scale confidence
            uncertainty = 0.15  # Low uncertainty

        # If RL says Hold or they disagree, lower confidence
        elif rl_direction == "Hold":
            final_direction = "Hold"
            confidence = 0.6 + (ensemble_prob - 0.5) * 0.2
            uncertainty = 0.4
        else:
            # Disagreement case: prefer the ensemble model due to its probabilistic nature
            if ensemble_pred[0] > 0.6:
                final_direction = "Buy"
                confidence = 0.6
            elif ensemble_pred[0] < 0.4:
                final_direction = "Sell"
                confidence = 0.6
            else:
                final_direction = "Hold"
                confidence = 0.5
            uncertainty = 0.5

        # Clip values
        confidence = max(0, min(1, confidence))
        uncertainty = max(0, min(1, uncertainty))

        return {
            "direction": final_direction,
            "confidence": round(confidence, 3),
            "uncertainty": round(uncertainty, 3),
            "rl_action": rl_direction,
            "ensemble_signal": "Bullish" if ensemble_pred[0] > 0.5 else "Bearish",
            "ensemble_prob": round(float(ensemble_pred[0]), 3)
        }


# --- 6. Risk Management (Monte Carlo VaR, Kelly Criterion) [citation:1][citation:2] ---
def calculate_risk_metrics(returns):
    """Calculates sophisticated risk metrics."""
    if len(returns) < 5:
        return {}

    # Value at Risk (VaR) at 95% and 99% confidence via Monte Carlo Simulation
    mean_return = np.mean(returns) if len(returns) > 0 else 0
    std_return = np.std(returns) if len(returns) > 0 else 0.01

    # Monte Carlo VaR (Simplified, assumes normal distribution) [citation:1]
    n_simulations = 10000
    simulated_returns = np.random.normal(mean_return, std_return, n_simulations)
    var_95 = np.percentile(simulated_returns, 5) * 100  # Value at Risk
    var_99 = np.percentile(simulated_returns, 1) * 100

    # Kelly Criterion [citation:1]
    if std_return > 0:
        kelly_fraction = (mean_return / (std_return ** 2)) if std_return > 0 else 0
        kelly_fraction = max(0, min(1, kelly_fraction))
    else:
        kelly_fraction = 0.1

    return {
        "Mean Daily Return": mean_return * 100,
        "Volatility (Std Dev)": std_return * 100,
        "VaR (95% Confidence)": var_95,
        "VaR (99% Confidence)": var_99,
        "Kelly Criterion (Optimal Fraction)": kelly_fraction,
        "Sharpe Ratio (Annualized)": (mean_return * 252) / (std_return * np.sqrt(252)) if std_return > 0 else 0
    }


# --- 7. Backtesting Engine ---
# NOTE: moved above the sidebar block below because it's called from inside
# that block (Streamlit executes the script top-to-bottom on every rerun,
# so the def must appear before the call site or it raises NameError).
def run_backtest(ai_system, data):
    """Simulates the trading strategy on historical data to generate performance metrics."""
    returns = []
    portfolio_values = []
    trades = []
    current_value = 10000
    shares = 0

    for i in range(50, min(len(data), 250)):
        # Use the AI system to generate a strategy for this point
        current_data = data.iloc[i]
        strategy = ai_system.generate_strategy(current_data)

        price = current_data['Close']

        # Simulate trade execution
        if strategy['direction'] == 'Buy' and shares == 0:
            shares = current_value * 0.95 // price
            current_value -= shares * price
            trades.append({'idx': i, 'type': 'Buy', 'price': price, 'shares': shares})
        elif strategy['direction'] == 'Sell' and shares > 0:
            current_value += shares * price
            shares = 0
            trades.append({'idx': i, 'type': 'Sell', 'price': price, 'shares': shares})

        # Update portfolio value
        current_portfolio_value = current_value + shares * price
        portfolio_values.append(current_portfolio_value)
        if i > 50:
            returns.append((current_portfolio_value - portfolio_values[-2]) / portfolio_values[-2])

    # Final liquidation
    if shares > 0:
        final_price = data.iloc[-1]['Close']
        current_value += shares * final_price
    final_portfolio_value = current_value

    return {
        'final_value': final_portfolio_value,
        'total_return': (final_portfolio_value - 10000) / 10000 * 100,
        'portfolio_values': portfolio_values,
        'trades': trades,
        'returns': returns
    }


